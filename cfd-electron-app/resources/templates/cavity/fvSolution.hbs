FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    p
    {
        solver          GAMG;
        tolerance       1e-7;
        relTol          0.01;
        smoother        GaussSeidel;
    }

    pFinal
    {
        $p;
        relTol          0;
    }

    U
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-7;
        relTol          0.1;
    }

    {{#if (eq turbulence 'kEpsilon')}}
    "k|epsilon"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-7;
        relTol          0.1;
    }
    {{/if}}
    {{#if (eq turbulence 'kOmegaSST')}}
    "k|omega"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-7;
        relTol          0.1;
    }
    {{/if}}
    {{#if (eq turbulence 'SpalartAllmaras')}}
    nuTilda
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-7;
        relTol          0.1;
    }
    {{/if}}
}

{{#if (eq solver 'icoFoam')}}
PISO
{
    nCorrectors     2;
    nNonOrthogonalCorrectors 0;
    pRefCell        0;
    pRefValue       0;
}
{{/if}}
{{#if (eq solver 'simpleFoam')}}
SIMPLE
{
    nNonOrthogonalCorrectors 0;
    residualControl
    {
        p               1e-4;
        U               1e-4;
        {{#unless (eq turbulence 'laminar')}}
        "(k|epsilon|omega|nuTilda)" 1e-4;
        {{/unless}}
    }
}
relaxationFactors
{
    fields
    {
        p               0.3;
    }
    equations
    {
        U               0.7;
        {{#unless (eq turbulence 'laminar')}}
        "(k|epsilon|omega|nuTilda)" 0.7;
        {{/unless}}
    }
}
{{/if}}
{{#if (eq solver 'pimpleFoam')}}
PIMPLE
{
    nOuterCorrectors 1;
    nCorrectors      2;
    nNonOrthogonalCorrectors 0;
}
{{/if}}


FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    // V1.18d — solver block lifted from Domain.solverConfigs.p. The
    //  smoother/preconditioner line is emitted via the `smootherLine`
    //  helper in case.ts (OpenFOAM needs the correct keyword per
    //  solver family — `smoother ...` for GAMG/smoothSolver,
    //  `preconditioner ...` for PCG/PBiCG/PBiCGStab).
    p
    {
        solver          {{solverConfigs.p.solver}};
        {{smootherLine solverConfigs.p.solver}}
        tolerance       {{solverConfigs.p.tolerance}};
        relTol          {{solverConfigs.p.relTol}};
    }

    pFinal
    {
        $p;
        relTol          0;
    }

    U
    {
        solver          {{solverConfigs.U.solver}};
        {{smootherLine solverConfigs.U.solver}}
        tolerance       {{solverConfigs.U.tolerance}};
        relTol          {{solverConfigs.U.relTol}};
    }

    {{#if (eq turbulence 'kEpsilon')}}
    "k|epsilon"
    {
        solver          {{solverConfigs.turbulence.solver}};
        {{smootherLine solverConfigs.turbulence.solver}}
        tolerance       {{solverConfigs.turbulence.tolerance}};
        relTol          {{solverConfigs.turbulence.relTol}};
    }
    {{/if}}
    {{#if (eq turbulence 'kOmegaSST')}}
    "k|omega"
    {
        solver          {{solverConfigs.turbulence.solver}};
        {{smootherLine solverConfigs.turbulence.solver}}
        tolerance       {{solverConfigs.turbulence.tolerance}};
        relTol          {{solverConfigs.turbulence.relTol}};
    }
    {{/if}}
    {{#if (eq turbulence 'SpalartAllmaras')}}
    nuTilda
    {
        solver          {{solverConfigs.turbulence.solver}};
        {{smootherLine solverConfigs.turbulence.solver}}
        tolerance       {{solverConfigs.turbulence.tolerance}};
        relTol          {{solverConfigs.turbulence.relTol}};
    }
    {{/if}}
}

{{#if (eq solver 'icoFoam')}}
PISO
{
    nCorrectors     {{numerics.nCorrectors}};
    nNonOrthogonalCorrectors {{numerics.nNonOrthogonalCorrectors}};
    pRefCell        0;
    pRefValue       0;
}
{{/if}}
{{!-- V1.47 — widen SIMPLE-block gate from `(eq solver 'simpleFoam')` to
     the SIMPLE-family check so buoyantSimpleFoam (and future potentialFoam)
     also render the SIMPLE block. Pre-V1.47 the SIMPLE block was gated on
     the literal solver string, which left buoyantSimpleFoam rendering
     WITHOUT nNonOrthogonalCorrectors, residualControl.p/U, and the
     nested T-residualControl line (`{{#if (eq solver 'buoyantSimpleFoam')}}`
     is INSIDE this gate — it wouldn't fire either). The result would
     crash OpenFOAM at first read of system/fvSolution.
     V1.46's buoyantSimpleFoam e2e it-case caught this gap; V1.47 fixes
     it. (Note: `or` block-helper is already used in the codebase via
     fvSchemes.hbs and partials.hbs, so no helper-registration needed.) --}}
{{#if (or (eq solver 'simpleFoam') (eq solver 'buoyantSimpleFoam'))}}
SIMPLE
{
    nNonOrthogonalCorrectors {{numerics.nNonOrthogonalCorrectors}};
    residualControl
    {
        p               {{or numerics.residualControlByField.p numerics.residualControl}};
        U               {{or numerics.residualControlByField.U numerics.residualControl}};
        {{#if (eq solver 'buoyantSimpleFoam')}}
        T               {{or numerics.residualControlByField.T numerics.residualControl}};
        {{/if}}
        {{#if (eq turbulence 'kEpsilon')}}
        k               {{or numerics.residualControlByField.k numerics.residualControl}};
        epsilon         {{or numerics.residualControlByField.epsilon numerics.residualControl}};
        {{/if}}
        {{#if (eq turbulence 'kOmegaSST')}}
        k               {{or numerics.residualControlByField.k numerics.residualControl}};
        omega           {{or numerics.residualControlByField.omega numerics.residualControl}};
        {{/if}}
        {{#if (eq turbulence 'SpalartAllmaras')}}
        nuTilda         {{or numerics.residualControlByField.nuTilda numerics.residualControl}};
        {{/if}}
    }
}
{{/if}}
{{!-- V1.11 review-fix #1 — hoist the relaxationFactors block out of
     the simpleFoam-only {{#if}} so buoyantSimpleFoam and potentialFoam
     (which both use SIMPLE-style under-relaxation in OpenFOAM and
     therefore need the block) also receive user overrides.
     V1.18b — replace the explicit solver-list with the precomputed
     `emitRelaxationFactors` boolean from case.ts. SIMPLE-family
     solvers (simpleFoam+buoyantSimpleFoam+potentialFoam) always
     emit; pimpleFoam emits only when the V1.18b UI opt-in flag is
     set. PISO solvers never emit (no under-relaxation in PISO).
     The boolean resolves to V1.11 behavior for pre-V1.18b cases
     (enabled=false on load → no PIMPLE block). --}}
{{#if emitRelaxationFactors}}
relaxationFactors
{
    fields
    {
        p               {{or relaxationFactors.fields.p 0.3}};
        {{#if (eq solver 'buoyantSimpleFoam')}}
        T               {{or relaxationFactors.fields.T 0.7}};
        {{/if}}
    }
    equations
    {
        U               {{or relaxationFactors.equations.U 0.7}};
        {{#if (eq turbulence 'kEpsilon')}}
        k               {{or relaxationFactors.equations.k 0.7}};
        epsilon         {{or relaxationFactors.equations.epsilon 0.7}};
        {{/if}}
        {{#if (eq turbulence 'kOmegaSST')}}
        k               {{or relaxationFactors.equations.k 0.7}};
        omega           {{or relaxationFactors.equations.omega 0.7}};
        {{/if}}
        {{#if (eq turbulence 'SpalartAllmaras')}}
        nuTilda         {{or relaxationFactors.equations.nuTilda 0.7}};
        {{/if}}
    }
}
{{/if}}
{{#if (eq solver 'pimpleFoam')}}
PIMPLE
{
    nOuterCorrectors {{numerics.nOuterCorrectors}};
    nCorrectors      {{numerics.nCorrectors}};
    nNonOrthogonalCorrectors {{numerics.nNonOrthogonalCorrectors}};
}
{{/if}}


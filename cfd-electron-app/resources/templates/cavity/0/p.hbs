FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

// V1.7 — initial pressure driven by the Build Case form's "Initial p" input.
//  Defaults to 0 for backward-compat with pre-V1.7 .cfd-app-state.json.
//  Incompressible solvers compute the pressure level via BCs, so the
//  absolute value is usually irrelevant beyond first-step smoothing.
internalField   uniform ({{initialConditions.pressure}});

boundaryField
{
    movingWall
    {
        type            zeroGradient;
    }
    fixedWalls
    {
        type            zeroGradient;
    }
    frontAndBack
    {
        type            empty;
    }
}

// ************************************************************************* //

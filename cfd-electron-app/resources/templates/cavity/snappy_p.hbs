FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Generated by CFD Studio geometry-prep V1.2.
// Per-patch pressure BCs come from the renderer's BC editor (defaults are
// zeroGradient; set outlet to fixedValue uniform 0 for incompressible
// flows, or leave zeroGradient if the solver computes the pressure level
// internally).

dimensions      [0 2 -2 0 0 0 0];
// V1.7 — initial pressure driven by the Build Case form's "Initial p" input.
//  Defaults to 0 for backward-compat. Incompressible solvers compute the
//  pressure level via the BCs, so this is mostly a first-step smoothing
//  value; set it to match the inlet/outlet static mean if you want to
//  avoid an initial transient in the residuals plot.
internalField   uniform ({{initialConditions.pressure}});

boundaryField
{
{{#each patches}}
    {{name}}
    {
        {{bcFor ../bc.pressure name}}
    }

{{/each}}
}


FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Generated by CFD Studio geometry-prep V1.2.
// Per-patch velocity BCs come from the renderer's BC editor (defaults are
// noSlip for walls). Edit the per-patch U value here for inlet/outlet
// profiles if a custom shape is needed.

dimensions      [0 1 -1 0 0 0 0];
// V1.7 — initial U driven by the Build Case form's "Initial U" inputs.
//  Defaults to (0 0 0) for backward-compat with pre-V1.7 .cfd-app-state.json.
//  For external-flow cases (cylinder/airfoil/channel), set this to the
//  freestream before building so the very first iteration isn't 0 m/s
//  everywhere.
internalField   uniform ({{initialConditions.velocity.x}} {{initialConditions.velocity.y}} {{initialConditions.velocity.z}});

boundaryField
{
{{#each patches}}
    {{name}}
    {
        {{bcFor ../bc.velocity name}}
    }

{{/each}}
}


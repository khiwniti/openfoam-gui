FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     {{solver}};

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         {{endTime}};

deltaT          {{deltaT}};

writeControl    timeStep;

writeInterval   {{writeInterval}};

purgeWrite      {{purgeWrite}};

writeFormat     ascii;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

// ************************************************************************* //

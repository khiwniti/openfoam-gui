FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Generated by CFD Studio geometry-prep V1.4 — per-patch refinement
// levels are emitted from the renderer's Patch settings section. Edit the
// mesh-quality tolerances as needed.

castellatedMesh true;
snap            true;
addLayers       false;        // turn on later for boundary-layer meshing

geometry
{
{{#each patches}}
    {{name}}.stl
    {
        type        triSurfaceMesh;
        name        {{name}};
    }

{{/each}}
}

castellatedMeshControls
{
    maxLocalCells       100000;
    maxGlobalCells      2000000;
    minRefinementCells  10;
    maxLoadUnbalance    0.10;
    nCellsBetweenLevels 3;

    resolution          ({{resolution}});
    locationInMesh      ({{locationInMesh}});
    allowFreeStandingZoneFaces true;

    // V1.4 — per-patch surface refinement levels. Min and max are 0..7;
    // typical 0..3. (0 0) means no surface refinement for that patch.
    refinementSurfaces
    {
{{#each patches}}
        {{name}}
        {
            {{refBlock ../patchRefinements name}}
        }
{{/each}}
    }
}

snapControls
{
    nSolverIter         30;
    nRelaxIter          5;
    nFeatureSnapIter    10;
    tolerance           1.0;

    implicitFeatureSnap false;
    explicitFeatureSnap true;
    multiRegionFeatureSnap false;
    detectBaffles       true;
}

meshQualityControls
{
    maxNonOrtho         65;
    maxBoundarySkewness 20;
    maxInternalSkewness 20;
    maxConcave          80;
    minFlatness         0.5;
    minVol              1e-13;
    minTetQuality       1e-30;
    minArea             -1;
    minTwist            0.05;
    minDeterminant      0.001;
    minFaceWeight       0.05;
    minVolRatio         0.01;
    nSmoothScale        4;
    errorReduction      0.75;
}

mergeTolerance 1e-6;

// ************************************************************************* //
